# ============================================================
# SafeStore AI - .gitignore
# ============================================================
# GitHub에 올라가면 안 되는 파일들 목록

# ── 환경 변수 (절대 올리면 안 됨!) ────────────────────────────
.env
.env.local
.env.*.local
*.env

# .env.example은 OK (실제 키는 없으니까)
!.env.example

# ── Python ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# 가상환경
venv/
env/
ENV/
.venv/

# ── IDE ────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ─────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# ── 로그·임시 파일 ─────────────────────────────────────────
*.log
logs/
*.tmp
tmp/

# ── 캐시·테스트 ─────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.dmypy.json

# ── 데이터 (필요 시 주석 처리) ───────────────────────────────
# CSV, Excel 등 대용량 데이터는 보통 제외
*.csv
*.xlsx
*.xls
# 단, 발표용 샘플 데이터는 허용하고 싶으면:
# !data/sample.csv

# ── 머신러닝 모델 (예외 처리) ─────────────────────────────────
# .pkl 파일은 보통 무거워서 제외하지만,
# SafeStore는 모델이 작아서 ml/models/ 안의 .pkl은 포함
# (Render 배포 시 필요)
# 만약 제외하려면 아래 주석 해제:
# *.pkl
# *.joblib

# ── 영상·이미지 (배경 이미지는 포함) ─────────────────────────
*.mp4
*.avi
*.mov

# ── 노트북 ───────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── 빌드 결과물 ────────────────────────────────────────────
build/
dist/
*.spec

# ── conda/pip ──────────────────────────────────────────────
pip-log.txt
pip-delete-this-directory.txt

# ── 기타 ───────────────────────────────────────────────────
# Mac 메타데이터
.AppleDouble
.LSOverride

# Windows
ehthumbs.db
[Dd]esktop.ini

# ========================================
# AI 모델 파일 (대용량, 별도 관리)
# ========================================
*.pt
models/
yolov8n-pose.pt

# ========================================
# 스냅샷 / 임시 파일
# ========================================
snapshots/
*.jpg
*.png

# ========================================
# Python 캐시
# ========================================
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# ========================================
# 환경변수
# ========================================
.env
.env.local

# ========================================
# 가상환경
# ========================================
venv/
env/
.venv/

# ========================================
# IDE
# ========================================
.vscode/
.idea/

# ========================================
# OS
# ========================================
.DS_Store
Thumbs.db